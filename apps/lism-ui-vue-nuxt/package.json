{
  "name": "@lism-ui-vue/nuxt",
  "version": "0.1.1-alpha.0",
  "description": "Lism-ui-vueのNuxtモジュール",
  "license": "MIT",
  "author": "Eita Kobayashi",
  "repository": {
    "type": "git",
    "url": "https://github.com/otusoa/lism-ui-vue"
  },
  "workspaces": [
    "playground"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "changelogen --release && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "lism-ui-vue": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "nuxt": "^4.4.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  }
}
