{
  "extends": "../../tsconfig.app.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "paths": {
      "@/*": ["../../src/*"],
      "root/*": ["../../*"]
    }
  },
  "include": [
    "src/**/*",
    "src/**/*.vue",
    ".storybook/**/*",
    "../../src/**/*",
    "../../src/**/*.vue"
  ]
}
