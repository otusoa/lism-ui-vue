{
  "extends": "../../tsconfig.app.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": false,
    "composite": true,
    "emitDeclarationOnly": true,
    "rootDir": "../../",
    "paths": {
      "@/*": ["../../src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "../../src/**/*.ts",
    "../../src/**/*.d.ts",
    "../../src/**/*.tsx",
    "../../src/**/*.vue"
  ]
}
