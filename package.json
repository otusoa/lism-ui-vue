{
  "name": "lism-ui-vue",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "author": "Eita Kobayashi",
  "repository": {
    "type": "git",
    "url": "https://github.com/otusoa/lism-ui-vue"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/lism-ui-vue.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lism-ui-vue.d.ts",
      "import": "./dist/index.js"
    },
    "./style": "./dist/lism-ui-vue.css"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "release": "pnpm run lint && pnpm run type-check && pnpm run build && changelogen --release && git push --follow-tags"
  },
  "dependencies": {
    "lism-css": "^0.9.3"
  },
  "devDependencies": {
    "@nuxt/schema": "^4.4.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "changelogen": "^0.6.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.35.0",
    "oxlint": "~1.50.0",
    "rolldown-plugin-dts": "^0.22.5",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
